// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

model User {
  id                   String       @id @default(cuid())
  email                String       @unique
  name                 String
  defaultLunchOptionId String?
  defaultLunchOption   LunchOption? @relation("UserDefaultLunch", fields: [defaultLunchOptionId], references: [id], onDelete: SetNull)

  presences   UserPresence[]
  lunchOrders LunchOrder[]
}

model UserPresence {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime

  @@unique([userId, date])
  @@index([date])
}

model LunchDay {
  id     String   @id @default(cuid())
  date   DateTime @unique
  reason String?

  orders LunchOrder[]
}

model LunchOption {
  id        String  @id @default(cuid())
  name      String
  breadType String
  price     Decimal

  defaultUsers User[]       @relation("UserDefaultLunch")
  lunchOrders  LunchOrder[]
}

model LunchOrder {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lunchOptionId String
  lunchOption   LunchOption @relation(fields: [lunchOptionId], references: [id], onDelete: Restrict)
  lunchDayId    String
  lunchDay      LunchDay    @relation(fields: [lunchDayId], references: [id], onDelete: Cascade)
  status        String

  @@unique([userId, lunchDayId])
}
